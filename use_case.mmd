flowchart LR
    %% Acteurs tous du même côté (à gauche)
    C(("Chauffeur")):::acteur
    B(("Back-office\nLogistique")):::acteur
    Admin(("Superviseur\nAdministrateur")):::acteur

    %% Système
    subgraph Systeme ["Application de Gestion de Livraison"]
        V1(["Consulter ses voyages"]):::cas
        V2(["Scanner la marchandise"]):::cas
        V3(["Confirmer arrivée chantier"]):::cas
        V4(["Signaler un incident"]):::casSpecial
        
        A1(["Préparer un voyage"]):::cas
        A2(["Éditer Bon de Livraison"]):::cas
        
        S1(["Suivre les chauffeurs GPS"]):::cas
        S2(["Gérer la flotte"]):::cas
        S3(["Consulter statistiques"]):::cas

        Auth(["S'authentifier"]):::casAuth
    end

    %% Liens Acteur -> Cas d'utilisation
    C --- V1
    C --- V2
    C --- V3

    B --- A1
    B --- A2
    B --- S1
    B --- S3

    Admin --- S1
    Admin --- S2
    Admin --- S3

    %% Includes & Extends : poussent Auth vers la droite
    V1 -. "&lt;&lt;include&gt;&gt;" .-> Auth
    V2 -. "&lt;&lt;include&gt;&gt;" .-> Auth
    V3 -. "&lt;&lt;include&gt;&gt;" .-> Auth
    A1 -. "&lt;&lt;include&gt;&gt;" .-> Auth
    A2 -. "&lt;&lt;include&gt;&gt;" .-> Auth
    S1 -. "&lt;&lt;include&gt;&gt;" .-> Auth
    S2 -. "&lt;&lt;include&gt;&gt;" .-> Auth
    S3 -. "&lt;&lt;include&gt;&gt;" .-> Auth
    
    V4 -. "&lt;&lt;extend&gt;&gt;" .-> V2
    V4 -. "&lt;&lt;extend&gt;&gt;" .-> V3

    %% Style Design (Retour à l'ancien design coloré)
    classDef acteur fill:#fde68a,stroke:#d97706,stroke-width:3px,color:#78350f,font-weight:bold;
    classDef cas fill:#e0f2fe,stroke:#0284c7,stroke-width:2px,color:#0369a1;
    classDef casAuth fill:#dbeafe,stroke:#1e3a8a,stroke-width:3px,color:#1e40af,font-weight:bold;
    classDef casSpecial fill:#fce7f3,stroke:#db2777,stroke-width:2px,color:#9d174d;
    style Systeme fill:#f8fafc,stroke:#94a3b8,stroke-width:2px,stroke-dasharray: 5 5
